{
  "name": "Badge",
  "type": "object",
  "properties": {
    "badge_number": {
      "type": "string",
      "description": "Num\u00e9ro unique du badge"
    },
    "type": {
      "type": "string",
      "enum": [
        "employe",
        "visiteur",
        "prestataire"
      ],
      "default": "employe"
    },
    "status": {
      "type": "string",
      "enum": [
        "actif",
        "inactif",
        "perdu",
        "suspendu"
      ],
      "default": "inactif"
    },
    "owner_name": {
      "type": "string"
    },
    "owner_email": {
      "type": "string"
    },
    "employee_id": {
      "type": "string"
    },
    "access_sites": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Sites autoris\u00e9s: usine, direction"
    },
    "access_points": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Points d'acc\u00e8s autoris\u00e9s"
    },
    "activated_by": {
      "type": "string",
      "description": "Email du technicien IT qui a activ\u00e9 le badge"
    },
    "activated_date": {
      "type": "string",
      "format": "date-time"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "badge_number",
    "type"
  ]
}